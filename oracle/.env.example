# RPC for the chain Toldya is deployed on (Taiko Hekla testnet by default)
RPC_URL=https://rpc.hekla.taiko.xyz

# Address of the deployed ToldyaHub contract
HUB_ADDRESS=0x0000000000000000000000000000000000000000

# Private key of the address authorized as the oracle on the hub
ORACLE_PRIVATE_KEY=0x...

# Anthropic API key for the resolver agent
ANTHROPIC_API_KEY=sk-ant-...

# Optional: block to start scanning from (defaults to latest)
START_BLOCK=
